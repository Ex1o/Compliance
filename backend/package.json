    "@nestjs/config": "^3.2.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "nestjs-pino": "^4.4.0",
    "@nestjs/bull": "^10.2.1",
    "@bull-board/express": "^5.17.1",
    "@bull-board/api": "^5.17.1",
    "@prisma/client": "^5.11.0",
    "@sentry/node": "^7.109.0",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.4",
    "bullmq": "^5.4.2",
