# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/compliancewala
REDIS_URL=redis://localhost:6379

# Auth — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_64_char_hex_string_generated_via_openssl
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
COOKIE_SECRET=replace_with_32_char_random_string

# Encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex_string_for_aes256_encryption

# OTP settings
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# MSG91 (OTP + SMS)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=CMPLWL
MSG91_OTP_TEMPLATE_ID=your_otp_template_id

# Interakt (WhatsApp Business API)
INTERAKT_API_KEY=your_interakt_api_key_base64
INTERAKT_WA_TEMPLATE_7D=compliance_reminder_7days
INTERAKT_WA_TEMPLATE_3D=compliance_reminder_3days
INTERAKT_WA_TEMPLATE_DUE=compliance_reminder_today
INTERAKT_WA_TEMPLATE_EXT=deadline_extension_alert

# Razorpay
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Sentry (production only)
SENTRY_DSN=https://xxx@sentry.io/xxx
